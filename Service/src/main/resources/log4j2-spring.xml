<?xml version="1.0" encoding="UTF-8"?>
<Configuration>
    <!--
    * JSONLayout makes it easier for DataDog to parse the log
    * Logging can be made Async by setting the java option -Dlog4j2.contextSelector=org.apache.logging.log4j.core.async.AsyncLoggerContextSelector
    This is done in the AWS task definition
    -->
    <Properties>
        <property name="CONSOLE_LOG_PATTERN">${springProperty:logging.pattern.console:-%clr{%d{yyyy-MM-dd HH:mm:ss.SSS}}{faint} %clr{%5p} %clr{:}{faint} %m%n%xwEx}</property>
        <property name="FILE_LOG_PATTERN">${springProperty:logging.pattern.file:-%d{yyyy-MM-dd HH:mm:ss.SSS} %5p ${pid} ---  [%t] %-40.40c{1.} : %X{correlation_id} : %m%n%xwEx}</property>
        <property name="LOG_FILE">${springProperty:logging.file.name:-logs/app.log}</property>
        <property name="LOG_FILE_PATTERN">${LOG_FILE}.%d{yyyy-MM-dd}.%i.gz</property>
    </Properties>

    <Appenders>
        <!-- Console Appender -->
        <Console name="ConsoleAppender" target="SYSTEM_OUT">
            <SpringProfile name="!local">
                <JSONLayout compact="true" eventEol="true" properties="true" stacktraceAsString="true"/>
            </SpringProfile>
            <SpringProfile name="local">
                <PatternLayout>
                    <Pattern>${CONSOLE_LOG_PATTERN}</Pattern>
                </PatternLayout>
            </SpringProfile>
        </Console>

        <!-- Rolling File Appender -->
        <SpringProfile name="local">
            <RollingFile name="FileAppender" fileName="${LOG_FILE}" filePattern="${LOG_FILE_PATTERN}">
                <PatternLayout>
                    <Pattern>${FILE_LOG_PATTERN}</Pattern>
                </PatternLayout>
                <Policies>
                    <SizeBasedTriggeringPolicy size="10 MB"/>
                </Policies>
            </RollingFile>
        </SpringProfile>
    </Appenders>

    <Loggers>
        <Root level="INFO">
            <AppenderRef ref="ConsoleAppender"/>
            <SpringProfile name="local">
                <AppenderRef ref="FileAppender"/>
            </SpringProfile>
        </Root>
    </Loggers>
</Configuration>
